@page "/"
@using Microsoft.AspNetCore.Mvc
@attribute [IgnoreAntiforgeryToken]
@using System.Text.Json
@using PonkoDockApp.Services
@rendermode InteractiveServer
@inject IDockerService DockerService
@inject IJSRuntime JS

<div class="app-container">
<div class="top-bar">
    <div class="d-flex align-items-center gap-2">
        <img src="@Assets["favicon-192x192.png"]" alt="Logo" style="width: 32px; height: 32px;" />
        <h1 class="text-center">PonkoDock</h1>
    </div>
</div>

    <div class="main-layout">
        <div class="sidebar">
            <div class="container-list">
                @if (!(containers?.Any() ?? false))
                {
                    <div class="p-3 text-muted text-center">No containers found.</div>
                }
                else
                {
                    foreach (var container in containers)
                    {
                        <div class="container-item @(selectedContainerId == container.ID ? "active" : "")" 
                             @onclick="() => SelectContainer(container.ID)">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong class="text-truncate" style="max-width: 180px;">@(container.Names?.FirstOrDefault()?.TrimStart('/') ?? "Unknown")</strong>
                                <span class="badge @(container.State == "running" ? "bg-success" : "bg-secondary")" style="font-size: 0.7rem;">@container.State</span>
                            </div>
                            <small class="d-block text-truncate" style="opacity: 0.8;">@container.Image</small>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="content-area">
            
            <div class="controls-section">
                <div class="row g-3 align-items-center">
                    <div class="col-md-4">
                        <h5 class="mb-1">@(selectedContainer?.Names?.FirstOrDefault()?.TrimStart('/') ?? "Unknown")</h5>
                        <small class="text-muted d-block">ID: @selectedContainer?.ID.Substring(0, 12)</small>
                        <small class="text-muted d-block">Image: @selectedContainer?.Image</small>
                        <small class="text-muted d-block">Ports: @GetPorts(selectedContainer)</small>
                    </div>

                    <div class="col-md-8 text-end">
                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-sm btn-outline-success" @onclick="() => Start(selectedContainer?.ID)">
                                <i class="bi bi-play-fill me-1"></i>Start
                            </button>
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => Stop(selectedContainer?.ID)">
                                <i class="bi bi-stop-fill me-1"></i>Stop
                            </button>
                            <button class="btn btn-sm btn-outline-info" @onclick="() => Restart(selectedContainer?.ID)">
                                <i class="bi bi-arrow-clockwise me-1"></i>Restart
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => Update(selectedContainer?.ID, selectedContainer?.Image)">
                                <i class="bi bi-cloud-download me-1"></i>Update
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Recreate(selectedContainer?.ID)">
                                <i class="bi bi-arrows-rotate me-1"></i>Recreate
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ViewInfo">
                                <i class="bi bi-info-circle me-1"></i>Info
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="logs-section">
                <div class="logs-header">
                    <span>Runtime Logs</span>
                    <div class="d-flex gap-2">
                        @if (!isListeningToLogs)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="StartListening">
                                <i class="bi bi-play-circle me-1"></i>Start Listening
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-danger" @onclick="StopListening">
                                <i class="bi bi-stop-circle me-1"></i>Stop Listening
                            </button>
                        }
                        <button class="btn btn-sm btn-outline-light" @onclick="ClearLogs">
                            <i class="bi bi-trash3 me-1"></i>Clear
                        </button>
                    </div>
                </div>
                <div class="logs-content" id="logWindow">
                    @foreach (var log in logEntries.ToList())
                    {
                        <div class="log-entry @(log.IsError ? "log-error" : "")">@log.Text</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (showInfoModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Container Info</h5>
                    <button type="button" class="btn-close" @onclick="() => showInfoModal = false"></button>
                </div>
                <div class="modal-body bg-light">
                    <pre style="font-size: 0.85rem; overflow: auto; max-height: 70vh;">@containerInfo</pre>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ContainerListResponse>? containers;
    private ContainerListResponse? selectedContainer;
    private string? selectedContainerId;
    
    private bool showInfoModal;
    private string? containerInfo;
    
    private readonly List<LogEntry> logEntries = new();
    private bool isListeningToLogs;
    private CancellationTokenSource? cts;

    protected override async Task OnInitializedAsync()
    {
        await LoadContainers();
    }

    private async Task LoadContainers()
    {
        containers = await DockerService.ListContainersAsync();
        if (containers != null && containers.Any() && selectedContainerId == null)
        {
            var first = containers.First();
            selectedContainerId = first.ID;
            selectedContainer = first;
        }
    }

    private Task SelectContainer(string? id)
    {
        if (string.IsNullOrEmpty(id)) return Task.CompletedTask;
        selectedContainerId = id;
        selectedContainer = containers?.FirstOrDefault(c => c.ID == id);
        StopListening();
        logEntries.Clear();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task Start(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        await DockerService.StartContainerAsync(id);
        await LoadContainers();
        if (selectedContainer != null) selectedContainer = containers?.FirstOrDefault(c => c.ID == id);
    }

    private async Task Stop(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        await DockerService.StopContainerAsync(id);
        await LoadContainers();
        if (selectedContainer != null) selectedContainer = containers?.FirstOrDefault(c => c.ID == id);
    }

    private async Task Restart(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        await DockerService.RestartContainerAsync(id);
        await LoadContainers();
        if (selectedContainer != null) selectedContainer = containers?.FirstOrDefault(c => c.ID == id);
    }

    private async Task Update(string? id, string? image)
    {
        if (string.IsNullOrEmpty(id) || string.IsNullOrEmpty(image)) return;
        try
        {
            await DockerService.PullImageAsync(image);
            await DockerService.RecreateContainerAsync(id);
            await LoadContainers();
            if (selectedContainer != null) selectedContainer = containers?.FirstOrDefault(c => c.ID == id);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task Recreate(string? id)
    {
        if(string.IsNullOrEmpty(id)) return;
        await DockerService.RecreateContainerAsync(id);
        await LoadContainers();
        if (selectedContainer != null) selectedContainer = containers?.FirstOrDefault(c => c.ID == id);
    }

    private async Task ViewInfo()
    {
        if (selectedContainer == null) return;
        var info = await DockerService.InspectContainerAsync(selectedContainer.ID);
        containerInfo = JsonSerializer.Serialize(info, new JsonSerializerOptions { WriteIndented = true });
        showInfoModal = true;
    }

    private async Task StartListening()
    {
        if (selectedContainer == null) return;
        
        if (isListeningToLogs) return;

        logEntries.Clear();

        isListeningToLogs = true;
        cts = new CancellationTokenSource();
        
        try
        {
            await foreach (var log in DockerService.GetContainerLogsAsync(selectedContainer.ID, cts.Token))
            {
                logEntries.Add(log);
                if (logEntries.Count > 1000)
                {
                    logEntries.RemoveAt(0);
                }
                await InvokeAsync(async () => 
                {
                    StateHasChanged();
                    await JS.InvokeVoidAsync("ponkodock.scrollToBottom");
                });
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            logEntries.Add(new LogEntry($"[Error streaming logs: {ex.Message}]", true));
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            isListeningToLogs = false;
        }
    }

    private void StopListening()
    {
        cts?.Cancel();
        cts = null;
        isListeningToLogs = false;
    }

    private void ClearLogs()
    {
        logEntries.Clear();
    }

    private static string GetPorts(ContainerListResponse? container)
    {
        try
        {
            var ports = container?.Ports;
            if (ports == null || !ports.Any()) return "None";
            
            var portList = new List<string>();
            foreach (var p in ports)
            {
                portList.Add($"{p.PublicPort}:{p.PrivatePort}");
            }
            return string.Join(", ", portList);
        }
        catch
        {
            return "None";
        }
    }
}
